record(bi, "$(P):$(R):LocRem") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 0 0x40 500)")  # Byte, bit 6
    field(ZNAM, "LOCAL")
    field(ONAM, "REMOTE")
    field(SCAN, "1 second")
}

record(longin, "$(P):$(R):GlobalStateRaw") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 0 0x3F 1000)")  # Byte, bit 5
    field(SCAN, "1 second")      # scansione periodica
   
}
###End offset zero on readback 
record(longin, "$(P):$(R):WayA_State") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 1 0x1F 1000)")  # Byte, bit 5
    field(SCAN, "1 second")      # scansione periodica
}

record(longin, "$(P):$(R):WayB_State") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 2 0x1F 1000)")  # Byte, bit 5
    field(SCAN, "1 second")      # scansione periodica
}
record(longin, "$(P):$(R):WayC_State") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 3 0x1F 1000)")  # Byte, bit 5
    field(SCAN, "1 second")      # scansione periodica
}
record(longin, "$(P):$(R):WayD_State") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 4 0x1F 1000)")  # Byte, bit 5
    field(SCAN, "1 second")      # scansione periodica
}

record(longin, "$(P):$(R):GroundCurrent_raw") {
    field(DTYP, "asynUInt32Digital")
    field(INP, "@asynMask($(READ_ALL) 14 0xffff 1000)")  
    field(FLNK, "$(P):$(R):GroundCurrent")
    field(SCAN, "1 second")      # scansione periodica
}

record(ai, "$(P):$(R):MaxGroundCurrent") {
    field(VAL, "500")
    field(PINI, "YES")  # inizializza all'avvio
}

record(calc, "$(P):$(R):GroundCurrent") {
    field(INPA, "$(P):$(R):GroundCurrent_raw NPP NMS")   # raw current
    field(INPB, "$(P):$(R):MaxGroundCurrent NPP NMS")       
    field(CALC, "(A - 32767.5)*((2*B)/65535)")
    field(PREC, "3")      # Precisione double
    field(EGU, "mA")       # Unità (mAmpere)
    field(SCAN, "Passive")
}

###End Ground Current on readback 
