record(ai, "$(P):$(R):MaxCurrent") {
    field(VAL, $(IMAX))
    field(PINI, "YES")  # inizializza all'avvio
}

record(ai, "$(P):$(R):CorrectionFactor") {
    field(VAL, "$(CORRECTION=1)")
    field(PINI, "YES")
}


record(calc, "$(P):$(R):WayA_Current") {
    field(INPA, "$(P):$(R):WayA_Current_raw NPP NMS")   # raw current
    field(INPB, "$(IMAX)")       
	field(INPC, "$(P):$(R):CorrectionFactor NPP NMS")       #euristic correction factor
    field(CALC, "(A - 32767.5)*((2*B)/65535)")
    field(PREC, "3")      # Precisione double
    field(EGU, "A")       # Unità (Ampere)
    field(SCAN, "Passive")
}
