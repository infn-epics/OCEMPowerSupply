##CONTROLS

record(ao, "$(P):$(R):GlobalControl") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(CMD_PORT) 0 1000)")
    field(PREC, "0")
    field(OMSL, "supervisory")
    #field(EGU,  "Command")
    field(DRVH, "16")     # valore massimo
    field(DRVL, "0")     # valore minimo
}

