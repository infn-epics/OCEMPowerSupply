record(ao, "$(P):$(R):WayA_Current_SP") {
    field(PREC, "3")      # Precisione double
    field(EGU, "A")       # Unità (Ampere)
    field(DRVH, $(IMAX))     # valore massimo
    field(DRVL, "-$(IMAX)") # valore minimo
    field(FLNK,"$(P):$(R):WayA_calc_current_raw")
}

record(calcout, "$(P):$(R):WayA_calc_current_raw") {
    field(INPA, "$(P):$(R):WayA_Current_SP")   # raw current
    field(INPB, "$(IMAX)")      
    field(INPC, "$(P):$(R):CorrectionFactor_Set")       
    field(CALC, "32767.5 +(32767.5/B)*A")
    field(OUT, "$(P):$(R):WayA_Iset_raw PP")
    #field(FLNK, "$(P):$(R):WayA_Iset_raw")
    field(PREC, "0")
}

